{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "messages": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["timestamp"],
      "$messageId": {
        ".validate": "newData.hasChildren(['text', 'uid', 'name']) && newData.child('text').isString() && newData.child('text').val().length > 0 && newData.child('text').val().length < 500"
      }
    },
    "quizScores": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email == 'wube8816@gmail.com'",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "admin": {
      "globalView": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.email == 'wube8816@gmail.com'"
      },
      "quizState": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.email == 'wube8816@gmail.com'"
      },
      "currentQuizData": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.email == 'wube8816@gmail.com'"
      },
      "kbcState": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.email == 'wube8816@gmail.com'",
        "players": {
          "$uid": {
            "submitted": {
              ".write": "auth != null && auth.uid == $uid"
            }
          }
        }
      }
    }
  }
}
